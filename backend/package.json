{
  "name": "backend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "kb:ingest-agents": "ts-node scripts/ingestAgentsToKb.ts",
    "dev": "tsx watch src/index.ts",
    "build": "echo '== prisma generate ==' && npx prisma generate && echo '== tsc ==' && npx tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker:engine": "node dist/workers/engineLoop.js",
    "worker:email": "node dist/workers/emailSender.js",
    "worker:scheduler": "node dist/workers/schedulerWorker.js",
    "worker:jobs": "node dist/workers/jobWorker.js",
    "worker:sms": "node dist/workers/smsWorker.js",
    "worker:reddit": "node dist/workers/redditWorker.js",
    "worker:social": "node dist/workers/socialMonitoringWorker.js",
    "worker:watchdog": "node dist/workers/watchdogWorker.js",
    "worker:local-vision": "tsx src/workers/localVisionAgent.ts",
    "worker:slack": "tsx watch src/workers/slackWorker.ts",
    "worker:treatment": "tsx src/workers/treatmentWorker.ts",
    "kb:chunk-docs": "ts-node scripts/chunkKbDocuments.ts",
    "kb:seed-docs": "npx tsx src/scripts/seedKbFromDocs.ts",
    "kb:seed-ai": "npx tsx src/scripts/seedAiKb.ts",
    "kb:backfill-tiers": "tsx src/scripts/backfillTiers.ts",
    "kb:reindex": "tsx src/scripts/reindexKb.ts",
    "kb:generate-golden": "npx tsx src/scripts/generateGoldenQueries.ts",
    "worker:kb-eval": "node dist/workers/kbEvalWorker.js",
    "seed:agents": "npx tsx src/scripts/seedAgents.ts",
    "kb:import-vc": "tsx src/scripts/importVcContacts.ts",
    "lucy:dev": "bash scripts/lucy-dev.sh"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@aws-sdk/s3-request-presigner": "^3.1008.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/websocket": "^11.2.0",
    "@google-cloud/speech": "^5.0.0",
    "@google-cloud/text-to-speech": "^5.8.1",
    "@pinecone-database/pinecone": "^7.1.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.48.1",
    "@zoom/appssdk": "^0.16.37",
    "@zoom/meetingsdk": "^5.1.2",
    "@zoom/videosdk": "^2.3.14",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dompurify": "^3.3.2",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "fastify": "^5.8.1",
    "fluent-ffmpeg": "^2.1.3",
    "jose": "^6.2.1",
    "openai": "^6.21.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "prisma": "^5.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
