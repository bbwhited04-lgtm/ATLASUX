# Frontend Environment Variables
# Copy these to your .env file

# Backend API URL - Required for frontend to communicate with backend
VITE_API_BASE_URL=https://api.atlasux.cloud

# Optional: Override default API URL
# VITE_BACKEND_URL=https://atlasux.cloud

# App gate code — Required for private beta access
VITE_APP_GATE_CODE=your-gate-code-here

# Development/Testing flags
VITE_USE_MOCKS=false

# DEPRECATED: Supabase auth has been replaced. These variables are no longer used.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
