# Frontend Environment Variables for Vercel Deployment
# Copy these to your Vercel project environment variables

# Backend API URL - Required for frontend to communicate with backend
VITE_API_BASE_URL=https://atlasux-backend.onrender.com

# Optional: Override default API URL
# VITE_BACKEND_URL=https://your-backend-url.onrender.com

# Supabase — Required for auth
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App gate code — Required for private beta access
VITE_APP_GATE_CODE=your-gate-code-here

# Development/Testing flags
VITE_USE_MOCKS=false
